{
  "name": "finance-tracker",
  "version": "1.0.0",
  "description": "Desktop finance tracker with MongoDB backend",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:electron\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "npm run build:frontend && npm run build:electron",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && venv\\Scripts\\python.exe -m PyInstaller --noconfirm finance_tracker_backend.spec",
    "build:electron": "electron-builder --win",
    "deploy": "npm run build:frontend && npm run build:backend && npm run build:electron",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.financetracker.desktop",
    "productName": "Finance Tracker",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/dist/finance-tracker-backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  },
  "keywords": [
    "finance",
    "tracker",
    "electron",
    "react",
    "mongodb"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "wait-on": "^7.2.0"
  }
}
